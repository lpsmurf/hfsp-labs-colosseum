# OpenRouter API key (required)
OPENROUTER_API_KEY=sk-or-v1-...

# Server port
PORT=8787

# Rate limit: messages per IP per UTC day
TRIAL_MESSAGES_PER_IP_PER_DAY=10

# Daily budget cap in USD
TRIAL_DAILY_BUDGET_USD=50

# Trust nginx X-Real-IP header (1 = enabled)
TRUST_PROXY=0

# CORS allowlist (comma-separated)
CORS_ORIGINS=https://clawdrop.live,http://localhost:3000

# Node environment
NODE_ENV=development

# Optional: log level
LOG_LEVEL=info
