{
  "name": "@clawdrop/mcp-server",
  "version": "0.1.0",
  "description": "Per-user Solana MCP server powered by SendAI Agent Kit — 60+ Solana tools",
  "main": "dist/server.cjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/server.cjs --external:better-sqlite3 --external:bufferutil --external:utf-8-validate --external:bigint-crypto-utils --external:rpc-websockets --external:@solana/web3.js --external:@triton-one/yellowstone-grpc",
    "start": "node dist/server.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@solana-agent-kit/adapter-mcp": "2.0.7",
    "@solana-agent-kit/plugin-defi": "2.0.8",
    "@solana-agent-kit/plugin-token": "2.0.9",
    "@solana/web3.js": "^1.98.0",
    "bs58": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.0",
    "solana-agent-kit": "2.0.10",
    "x402engine-mcp": "^1.0.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "esbuild": "0.24.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
