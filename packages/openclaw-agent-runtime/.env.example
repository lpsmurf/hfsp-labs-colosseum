# Injected per-user at container startup
USER_ID=
MCP_URL=http://localhost:3002
LLM_PROVIDER=poly            # poly | byok | custom
LLM_MODEL=claude-haiku-4-5
LLM_API_KEY=                 # only for byok
CUSTOM_ENDPOINT=             # only for custom
OPENCLAW_PLATFORM_URL=http://host.docker.internal:8788
LOOP_INTERVAL_SECONDS=60
HEALTH_PORT=3999
