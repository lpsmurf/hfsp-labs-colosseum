# Clawdrop MCP Environment Configuration
# Copy this file to .env and fill in your values

# Solana RPC
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_DEVNET_RPC=https://devnet.helius-rpc.com/?api-key=your_key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_key

# Payment Configuration
CLAWDROP_WALLET_ADDRESS=your_payment_receiving_wallet
CLAWDROP_FEE_WALLET=your_fee_wallet

# HFSP API Configuration
HFSP_API_URL=http://localhost:3001
HFSP_API_KEY=your_hfsp_api_key

# Birdeye API
BIRDEYE_API_KEY=your_birdeye_api_key

# Feature Flags
ENABLE_AUTO_SWAP=true
ENABLE_RISK_CHECK=true

# Server Configuration
PORT=3000
NODE_ENV=development
