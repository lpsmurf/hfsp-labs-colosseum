# Clawdrop MCP Environment Configuration
# Copy this file to .env.local and fill in your values

# Solana RPC
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_DEVNET_RPC=https://devnet.helius-rpc.com/?api-key=your_key

# Wallet (for testing only - never commit real private keys)
WALLET_PUBLIC_KEY=your_wallet_public_key
# WALLET_PRIVATE_KEY=your_base58_private_key  # Uncomment only for local dev

# Birdeye API
BIRDEYE_API_KEY=your_birdeye_api_key

# Jito Configuration
JITO_RPC_URL=https://mainnet.block-engine.jito.wtf/api/v1
JITO_MIN_SWAP_USD=5000

# DD.xyz Risk Policy
DD_XYZ_API_KEY=your_dd_xyz_key_here
RISK_POLICY=normal
WHITELIST_TOKENS=So11111111111111111111111111111111111111112,EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Payment Configuration
CLAWDROP_WALLET_ADDRESS=your_payment_receiving_wallet

# Feature Flags
ENABLE_AUTO_SWAP=true
ENABLE_RISK_CHECK=true

# Server Configuration
PORT=3000
NODE_ENV=development
