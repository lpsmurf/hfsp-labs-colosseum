{
  "name": "clawdrop-mcp",
  "version": "0.2.0",
  "description": "Clawdrop MCP Server - Deploy and manage AI agents on Solana",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "CLAWDROP_MODE=mcp node --loader ts-node/esm --experimental-specifier-resolution=node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src"
  },
  "bin": {
    "clawdrop-mcp": "bin/clawdrop-mcp.sh",
    "clawdrop-server": "bin/clawdrop-mcp.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@solana/web3.js": "^1.91.0",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.4",
    "pino": "^8.19.0",
    "pino-pretty": "^10.2.3",
    "tweetnacl": "^1.0.3",
    "yargs": "^17.7.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  }
}