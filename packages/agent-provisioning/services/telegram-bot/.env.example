# [KIMI] Environment variables template

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=<from @BotFather>
TELEGRAM_BOT_ID=<numeric ID from @BotFather>
TELEGRAM_SECRET_TOKEN=<generate: openssl rand -hex 32>
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/telegram/webhook

# Agent Brain Configuration
# For local development: http://localhost:3334
# For Docker: http://agent-brain:3334
AGENT_BRAIN_URL=http://localhost:3334

# Server Configuration
PORT=3335
NODE_ENV=development
DEBUG=false

# Optional Telegram token file path (for production/Docker)
# If set, uses this file instead of TELEGRAM_BOT_TOKEN env var
# TELEGRAM_BOT_TOKEN_FILE=/run/secrets/telegram_bot_token
