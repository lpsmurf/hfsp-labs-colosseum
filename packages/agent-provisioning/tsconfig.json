{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0",
    "sourceMap": true
  },
  "include": [
    "services/storefront-bot/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "services/webapp",
    "services/clawdrop-wizard",
    "dist"
  ]
}
