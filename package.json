{
  "name": "@hfsp-labs/clawdrop",
  "version": "1.0.0",
  "description": "HFSP Labs unified monorepo for Clawdrop MCP and Agent Provisioning",
  "private": true,
  "bin": {
    "clawdrop": "./packages/clawdrop-mcp/cli.cjs",
    "clawdrop-mcp": "./packages/clawdrop-mcp/bin/clawdrop-mcp.sh"
  },
  "scripts": {
    "postinstall": "cd packages/clawdrop-mcp && npm install && npm run build",
