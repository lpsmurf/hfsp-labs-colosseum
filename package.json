{
  "name": "clawdrop-mcp",
  "version": "0.1.0",
  "description": "Clawdrop MCP Server - Crypto service orchestration for Claude Code",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src",
    "test:tools": "tsx scripts/quick-test.ts",
    "monitor": "tsx scripts/monitor.ts",
    "demo:advanced": "tsx scripts/demo-advanced.ts",
    "test:watch": "jest --watch",
    "api": "CLAWDROP_MODE=api tsx watch src/index.ts",
    "both": "CLAWDROP_MODE=both tsx watch src/index.ts",
    "cli": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "pino": "^8.17.0",
    "solana-mcp-server": "^1.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ts-jest": "^29.4.9",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "bin": {
    "clawdrop": "dist/cli/index.js"
  }
}
