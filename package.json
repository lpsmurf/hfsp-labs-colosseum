  },
  "bugs": {
    "url": "https://github.com/lpsmurf/hfsp-labs-colosseum/issues"
  },
  "homepage": "https://hfsp.labs",
  "bin": {
    "clawdrop": "./mcp-server.js"
  },
  "main": "./mcp-server.js",
  "type": "module"
}
